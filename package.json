{
  "name": "nanobot-agent-console",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n backend,desktop -c blue,green \"npm run dev --workspace @nanobot/backend\" \"npm run dev --workspace @nanobot/desktop\"",
    "dev:backend": "npm run dev --workspace @nanobot/backend",
    "dev:desktop": "npm run dev --workspace @nanobot/desktop",
    "build:backend:sidecar": "npm run package:sidecar --workspace @nanobot/backend",
    "build:desktop:bundle": "npm run bundle --workspace @nanobot/desktop",
    "dist": "npm run build:desktop:bundle",
    "lint": "npm run lint:backend && npm run lint:desktop",
    "lint:backend": "npm run lint --workspace @nanobot/backend",
    "lint:desktop": "npm run lint --workspace @nanobot/desktop",
    "format": "npm run format:backend && npm run format:desktop",
    "format:backend": "npm run format --workspace @nanobot/backend",
    "format:desktop": "npm run format --workspace @nanobot/desktop",
    "test": "npm run test:backend && npm run test:desktop",
    "test:backend": "npm run test --workspace @nanobot/backend",
    "test:desktop": "npm run test --workspace @nanobot/desktop"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.6.2"
  }
}
